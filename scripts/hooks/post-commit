#!/usr/bin/env bash
set -euo pipefail

# Prevent infinite loop: skip if this commit was generated by this hook
COMMIT_MSG=$(git log -1 --pretty=%B HEAD)
if echo "$COMMIT_MSG" | grep -qF "[auto-docs]"; then
  exit 0
fi

# Only run when code files changed (.go, .proto, go.mod, Makefile)
CHANGED_CODE=$(git diff-tree --no-commit-id -r --name-only HEAD \
  | grep -E '\.(go|proto|mod|sum)$|^Makefile$' || true)

if [ -z "$CHANGED_CODE" ]; then
  exit 0
fi

# Require claude CLI
if ! command -v claude &>/dev/null; then
  echo "[auto-docs] claude CLI não encontrado — pulando atualização do CLAUDE.md"
  exit 0
fi

echo "[auto-docs] Detectadas mudanças em código — atualizando CLAUDE.md..."

# Build diff command (handles first commit case)
if git rev-parse --verify HEAD~1 &>/dev/null; then
  DIFF=$(git diff HEAD~1 HEAD -- $CHANGED_CODE)
else
  DIFF=$(git show HEAD -- $CHANGED_CODE)
fi

# Ask Claude to review the diff and update CLAUDE.md
claude -p "Você é um agente de documentação. Revise o CLAUDE.md do projeto e atualize-o para refletir as mudanças abaixo (apenas seções impactadas pelas mudanças: arquitetura, comandos, fluxo de dependências, integrações). Não adicione conteúdo desnecessário. Não altere o estilo ou estrutura existente do arquivo.

Arquivos alterados:
$CHANGED_CODE

Diff:
$DIFF" \
  --allowedTools "Bash,Read,Edit" \
  --output-format text \
  2>/dev/null || {
    echo "[auto-docs] claude retornou erro — CLAUDE.md não foi alterado"
    exit 0
  }

# If CLAUDE.md changed, create a follow-up commit
if ! git diff --quiet CLAUDE.md 2>/dev/null; then
  git add CLAUDE.md
  git commit -m "docs: atualiza CLAUDE.md [auto-docs]"
  echo "[auto-docs] CLAUDE.md atualizado e commitado."
else
  echo "[auto-docs] CLAUDE.md não precisou de alterações."
fi
